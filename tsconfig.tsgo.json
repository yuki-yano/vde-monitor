{
  // tsgo (@typescript/native-preview) が baseUrl をサポートしないため、IDE 用 tsconfig.json と分離している。
  // paths はすべて ./ プレフィックス付き。統合の検討は PLAN-20260224-001 完了後。
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./apps/web/src/*"],
      "@vde-monitor/server": ["./apps/server/src/index.ts"],
      "@vde-monitor/server/*": ["./apps/server/src/*"],
      "@vde-monitor/*": ["./packages/*/src"]
    }
  },
  "include": ["apps/**/*", "packages/**/*"],
  "exclude": ["**/dist", "**/node_modules"]
}
