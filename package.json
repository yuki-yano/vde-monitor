{
  "name": "vde-monitor",
  "description": "Monitor coding sessions across supported terminal backends with a web UI.",
  "author": "Yuki Yano",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yuki-yano/vde-monitor.git"
  },
  "version": "0.14.1",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24.11.0"
  },
  "bin": {
    "vde-monitor": "dist/index.js",
    "vde-monitor-hook": "dist/vde-monitor-hook.js"
  },
  "files": [
    "dist/**",
    "LICENSE",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "tsx scripts/build-package.ts",
    "build:watch": "tsx scripts/build-watch.ts",
    "build:web": "pnpm --filter @vde-monitor/web build",
    "prepack": "pnpm build",
    "dev": "tsx scripts/dev.ts",
    "dev:public": "tsx scripts/dev.ts --public",
    "dev:server": "pnpm --filter @vde-monitor/server dev",
    "dev:server:public": "pnpm --filter @vde-monitor/server dev -- --public",
    "dev:web": "pnpm --filter @vde-monitor/web dev",
    "dev:web:public": "pnpm --filter @vde-monitor/web dev:public",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint -c .oxlintrc.json . --report-unused-disable-directives-severity=error",
    "lint:fix": "oxlint --fix -c .oxlintrc.json . --report-unused-disable-directives-severity=error",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest",
    "test:diff": "pnpm exec vitest related --run --passWithNoTests $(bash scripts/list-diff-related-files.sh)",
    "test:run": "vitest run",
    "ci": "concurrently -n format,typecheck,lint,test -p \"{name}\" --pad-prefix --kill-others-on-fail \"pnpm run format:check\" \"pnpm run typecheck\" \"pnpm run lint\" \"pnpm run test:run\"",
    "ci:diff": "concurrently -n format,typecheck,lint -p \"{name}\" --pad-prefix --kill-others-on-fail \"pnpm run format:check\" \"pnpm run typecheck\" \"pnpm run lint\" && pnpm run test:diff",
    "ci:fix": "pnpm run format && pnpm run typecheck && pnpm run lint:fix && pnpm run test:run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "catalog:",
    "@hono/node-server": "catalog:",
    "@hono/zod-validator": "catalog:",
    "execa": "catalog:",
    "hono": "catalog:",
    "qrcode-terminal": "catalog:",
    "web-push": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.13.3",
    "@types/web-push": "^3.6.4",
    "concurrently": "^10.0.3",
    "happy-dom": "^20.10.6",
    "msw": "^2.15.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.4",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
